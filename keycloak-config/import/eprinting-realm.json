{
  "realm": "eprinting",
  "enabled": true,
  "displayName": "Eprinting",
  "displayNameHtml": "<h2>Eprinting Application</h2>",
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,

  "clients": [
    {
      "clientId": "eprinting-backend",
      "name": "Eprinting Backend",
      "enabled": true,
      "secret": "your-client-secret",
      "redirectUris": [
        "http://localhost:8080/*",
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:8080",
        "http://localhost:4200"
      ],
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    },
    {
      "clientId": "eprinting-frontend",
      "name": "Eprinting Frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200"
      ],
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect"
    }
  ],

  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@eprinting.com",
      "firstName": "Admin",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin", "user"]
    },
    {
      "username": "user",
      "enabled": true,
      "email": "user@eprinting.com",
      "firstName": "Regular",
      "lastName": "User",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "user123",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ]
}