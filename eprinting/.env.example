SHIPPO_API_TOKEN=replace_with_real_value_in_local_env_only
SHIPPO_WEBHOOK_SECRET=
SHIPPO_TEST_MODE=true
SHIPPO_REAL_CARRIER_CONFIGURED=false
SHIPPO_DEFAULT_SERVICE=standard
