SPRING_APPLICATION_NAME=eprinting
SERVER_PORT=8080

MYSQL_DATABASE=eprinting_db
MYSQL_ROOT_PASSWORD=change_me
MYSQL_USER=root
MYSQL_PASSWORD=

SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/eprinting_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true&createDatabaseIfNotExist=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=

SPRING_JPA_HIBERNATE_DDL_AUTO=create
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_FORMAT_SQL=true
SPRING_SQL_INIT_MODE=always
SPRING_SQL_INIT_CONTINUE_ON_ERROR=true
SPRING_SQL_INIT_DATA_LOCATIONS=classpath:users_dump.sql,classpath:books_dump.sql

SECURITY_AUTHENTICATION_MODE=jwt
JWT_SECRET=change-me-please-change-me-please-123456789
JWT_EXPIRATION_SECONDS=86400

STRIPE_SECRET_KEY=replace_with_real_value_in_local_env_only
STRIPE_WEBHOOK_SECRET=replace_with_real_value_in_local_env_only
STRIPE_PUBLIC_KEY=replace_with_real_value_in_local_env_only

